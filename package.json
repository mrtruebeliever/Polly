      "AUDIO_TOTAL_LEN",
      "AUDIO_CHUNK_INDEX",
      "AUDIO_CHUNK",
      "AUDIO_DONE",
      "TTS_ERROR",
      "TTS_API_KEY",
      "VOICE_LANG",
      "VOICE_NAME",
      "IDLE_ANIM_ENABLED",
      "IDLE_ANIM_FREQ",
      "SPEECH_VOLUME",
      "PRESET_1",
      "PRESET_2",
      "PRESET_3",
      "PRESET_4"
